# --- Claude API (required) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- NCBI / PubMed (optional but recommended for higher rate limits) ---
# Get an API key at: https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=
NCBI_TOOL=tavr-digest
NCBI_EMAIL=your@email.com

# --- Email SMTP ---
# For Gmail: enable 2FA, then create an App Password at
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM=your@gmail.com
EMAIL_TO=your@gmail.com

# --- Agent Settings ---
PUBMED_MAX_RESULTS=50
NEWS_MAX_RESULTS=30
LOOKBACK_DAYS=1
CLAUDE_MODEL=claude-sonnet-4-20250514
LOG_LEVEL=INFO
